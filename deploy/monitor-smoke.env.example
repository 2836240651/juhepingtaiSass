# Copy this file on the server to /data/crosshub/.monitor-smoke.env.
# Fill either CROSSHUB_MONITOR_API_TOKEN or the login account/password pair.
# Keep the real file private on the server and never commit it.

CROSSHUB_MONITOR_API_TOKEN=

CROSSHUB_MONITOR_LOGIN_ACCOUNT=
CROSSHUB_MONITOR_LOGIN_PASSWORD=
CROSSHUB_MONITOR_PORTAL_ROLE=boss

CROSSHUB_MONITOR_SMOKE_TIMEOUT_MS=60000
