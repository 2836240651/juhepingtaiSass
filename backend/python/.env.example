# Temu 爬虫环境变量（复制为 .env）
# 默认有头模式 + 本机 Chrome，降低被 Temu 识别为自动化的概率
TEMU_HEADLESS=0
TEMU_BROWSER_CHANNEL=chrome
# 若无 Chrome 可改为 msedge 或留空使用 Playwright Chromium
# TEMU_BROWSER_CHANNEL=

# 持久化登录态目录（勿提交 git）
# TEMU_PROFILE_DIR=./.temu-browser-profile

# 请求间隔（毫秒），模拟人工操作
TEMU_MIN_DELAY_MS=800
TEMU_MAX_DELAY_MS=2200

# 紫鸟 WebDriver（复制为 .env 并填写；勿提交 git）
# 文档: https://open.ziniao.com/docSupport?docId=98
# ZINIAO_COMPANY=企业全称（紫鸟左上角显示）
# ZINIAO_USERNAME=自动化子账号
# ZINIAO_PASSWORD=
# ZINIAO_CLIENT_PATH=C:\Program Files\ziniao\ziniao.exe
# ZINIAO_SOCKET_PORT=16851
